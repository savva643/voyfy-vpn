# Voyfy VPN Docker Environment Configuration
# Generate secure secrets before deploying!

# ==========================================
# Database Configuration
# ==========================================
DB_USER=voyfy
DB_PASSWORD=voyfy_secure_password_change_this
DB_NAME=voyfy_vpn

# ==========================================
# JWT Configuration
# Generate with: openssl rand -hex 32
# ==========================================
JWT_SECRET=change_this_jwt_secret_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=change_this_refresh_secret_generate_with_openssl_rand_hex_32

# ==========================================
# Xray Configuration
# Generate keys with: docker run --rm teddysun/xray xray x25519
# ==========================================
XRAY_PUBLIC_KEY=change_this_to_your_xray_public_key
XRAY_PRIVATE_KEY=change_this_to_your_xray_private_key
XRAY_SERVER_NAME=www.microsoft.com
XRAY_SHORT_ID=change_this_short_id_8_hex_chars
XRAY_PORT=443
XRAY_API_PORT=10085

# ==========================================
# Admin API Key (for server registration)
# ==========================================
ADMIN_API_KEY=change_this_to_secure_admin_api_key

