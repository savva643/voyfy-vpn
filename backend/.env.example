# Voyfy VPN Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=voyfy_vpn
DB_USER=voyfy
DB_PASSWORD=change_me_in_production

# ==========================================
# JWT Configuration
# Generate with: openssl rand -hex 32
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# External Auth Service (Optional)
# For future integration with existing ecosystem
# ==========================================
EXTERNAL_AUTH_ENABLED=false
AUTH_SERVICE_URL=https://auth.yourdomain.com

# ==========================================
# Xray Configuration
# Generate keys with: docker run --rm teddysun/xray xray x25519
# ==========================================
XRAY_PUBLIC_KEY=your_xray_public_key_here
XRAY_PRIVATE_KEY=your_xray_private_key_here
XRAY_SERVER_NAME=www.microsoft.com
XRAY_SHORT_ID=0123456789abcdef
XRAY_PORT=443
XRAY_API_PORT=10085

# ==========================================
# Server Configuration
# ==========================================
PORT=4000
NODE_ENV=production
LOG_LEVEL=info

# ==========================================
# CORS Configuration
# ==========================================
# For production, specify your domains
CORS_ORIGIN=https://vip.necsoura.ru,https://185.164.163.166

# ==========================================
# Frontend URL (for redirects)
# ==========================================
FRONTEND_URL=https://vip.necsoura.ru
